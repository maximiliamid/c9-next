# Caddy TLS reverse proxy in front of Cloud9.
# Serves HTTPS on :8443 (inside the container) for the host set in C9_HOST, using Caddy's
# INTERNAL (self-signed) CA — no domain registrar and no port 80 needed. Set C9_HOST in .env to
# your server's IP or domain so the self-signed cert matches what you type in the browser.
#
# Self-signed → the browser warns "not trusted"; click through (traffic is still encrypted).
# REAL trusted cert later: set C9_HOST to a real domain pointed at this host, free port 80, and
# change `tls internal` to just remove it — Caddy then auto-issues + renews Let's Encrypt.

{$C9_HOST:localhost}:8443 {
	tls internal
	encode gzip zstd
	reverse_proxy c9:8181
}
