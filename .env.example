# Copy to .env and set a STRONG password, then: docker compose up -d --build
C9_USERNAME=cloud9
C9_PASSWORD=change-me-please

# The HOSTNAME the cert is issued for — must match what you type in the browser.
# IMPORTANT: a bare IP can't be used (TLS doesn't send IPs as SNI, so the cert won't match).
# If you only have an IP and no domain, use the free wildcard DNS nip.io:
#   C9_HOST=<your-ip-with-dashes-or-dots>.nip.io   e.g. 203.0.113.10.nip.io  -> resolves to 203.0.113.10
# With a real domain pointed here: C9_HOST=ide.example.com
C9_HOST=localhost

# Public HTTPS port served by Caddy (c9 itself is NOT exposed directly).
# 80/443 are often taken by other services — 8443 is a safe default.
C9_HTTPS_PORT=8443

# Where your code lives on the host (mounted into the IDE at /workspace).
C9_WORKSPACE=./workspace
